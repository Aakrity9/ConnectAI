# Connect AI Backend Environment Variables

PORT=3001

# PostgreSQL Database Connection URL (e.g. Neon, Aiven, or Local)
# Note: Ensure the pgvector extension is enabled on this database instance.
DATABASE_URL="postgresql://username:password@hostname:5432/database_name?sslmode=require"

# Redis cache connection URL (used for BullMQ background queues and cached matches)
REDIS_URL="redis://localhost:6379"

# Clerk Security Credentials (from your Clerk dashboard API Keys tab)
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# AI Services Integration Keys (for embeddings and chat completions)
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
